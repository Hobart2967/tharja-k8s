dnsRecords:
- zone: avsn.de
  records:
  - name: mail
    type: A

  - name: mail
    type: MX
    priority: "10"
    mailServer: "mail.avsn.de."

  - name: www
    type: A

- zone: adventurespiele.net
  records:
  - name: mail
    type: A

  - name: mail
    type: MX
    priority: "10"
    mailServer: "mail.adventurespiele.net."

  - name: www
    type: A
