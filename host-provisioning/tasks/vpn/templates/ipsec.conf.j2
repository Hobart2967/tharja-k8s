# /etc/ipsec.conf - strongSwan IPsec configuration file
# Generated by Ansible

config setup
    charondebug="{{ vpn.ipsec.charon_debug | default('ike 1, knl 1, cfg 0') }}"
    uniqueids={{ vpn.ipsec.unique_ids | default('no') }}

{% for connection in vpn.connections | default([]) %}
conn {{ connection.name }}
    keyexchange={{ connection.keyexchange | default('ikev1') }}
    ike={{ connection.ike | default('aes256-sha1-modp1024!') }}
    esp={{ connection.esp | default('aes256-sha1!') }}
    ikelifetime={{ connection.ikelifetime | default('3h') }}
    keylife={{ connection.keylife | default('1h') }}
    rekeymargin={{ connection.rekeymargin | default('3m') }}
    keyingtries={{ connection.keyingtries | default('1') }}

    # Left (local) side
{% if connection.force_ipv4 | default(false) %}
    left=%any4
{% else %}
    left={{ connection.left | default('%defaultroute') }}
{% endif %}
    leftauth={{ connection.leftauth | default('psk') }}
    leftid={{ secret_values[connection.leftid] }}
    leftsourceip=%config
{% if connection.xauth_username is defined and connection.keyexchange | default('ikev1') == 'ikev1' %}
    xauth_identity={{ secret_values[connection.xauth_username] }}
{% endif %}
{% if connection.xauth_username is defined and connection.keyexchange | default('ikev1') == 'ikev2' %}
    leftauth=eap-mschapv2
    eap_identity={{ secret_values[connection.xauth_username] }}
{% endif %}
{% if connection.leftsubnet is defined %}
    leftsubnet={{ connection.leftsubnet }}
{% endif %}
{% if connection.leftfirewall is defined %}
    leftfirewall={{ connection.leftfirewall }}
{% endif %}

    # Right (remote) side
    right={{ secret_values[connection.right] }}
    rightauth={{ connection.rightauth | default('psk') }}
{% if connection.xauth_username is defined and connection.keyexchange | default('ikev1') == 'ikev1' %}
    rightauth2=xauth
{% endif %}
{% if connection.xauth_username is defined and connection.keyexchange | default('ikev1') == 'ikev2' %}
    rightauth2=eap-mschapv2
{% endif %}
{% if connection.rightid is defined %}
    rightid={{ connection.rightid }}
{% endif %}
{% if connection.rightsubnet is defined %}
    rightsubnet={{ connection.rightsubnet }}
{% endif %}

    # Connection settings
    auto={{ connection.auto | default('start') }}
    closeaction={{ connection.closeaction | default('restart') }}
    dpdaction={{ connection.dpdaction | default('restart') }}
    dpddelay={{ connection.dpddelay | default('30s') }}
    dpdtimeout={{ connection.dpdtimeout | default('120s') }}
    installpolicy=yes
{% if connection.type is defined %}
    type={{ connection.type }}
{% endif %}
{% if connection.mark is defined %}
    mark={{ connection.mark }}
{% endif %}

{% endfor %}
