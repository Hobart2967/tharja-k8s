#!/bin/bash
# VPN Health Check Script
# Checks if VPN connections are up and restarts them if needed

LOG_FILE="/var/log/vpn-healthcheck.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

{% for connection in vpn.connections | default([]) %}
# Check connection: {{ connection.name }}
CONNECTION_NAME="{{ connection.name }}"
CONNECTION_STATUS=$(ipsec status "$CONNECTION_NAME" 2>&1)

if echo "$CONNECTION_STATUS" | grep -q "ESTABLISHED"; then
    log "✓ VPN connection '$CONNECTION_NAME' is up"
else
    log "✗ VPN connection '$CONNECTION_NAME' is down - attempting to bring it up"

    # Try to bring up the connection
    ipsec up "$CONNECTION_NAME" >> "$LOG_FILE" 2>&1

    # Wait a moment and check again
    sleep 3

    if ipsec status "$CONNECTION_NAME" 2>&1 | grep -q "ESTABLISHED"; then
        log "✓ Successfully restored VPN connection '$CONNECTION_NAME'"
    else
        log "✗ Failed to restore VPN connection '$CONNECTION_NAME'"
    fi
fi

{% endfor %}
