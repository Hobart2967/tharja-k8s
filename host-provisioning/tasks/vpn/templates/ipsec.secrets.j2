# /etc/ipsec.secrets - strongSwan IPsec secrets file
# Generated by Ansible

{% for connection in vpn.connections | default([]) %}
{% if connection.psk is defined %}
# Pre-shared key for {{ connection.name }}
{{ secret_values[connection.leftid] }} {{ connection.rightid | default(connection.right) }} : PSK "{{ secret_values[connection.psk] }}"
{% endif %}
{% if connection.xauth_username is defined and connection.xauth_password is defined %}
# User credentials for {{ connection.name }}
{% if connection.keyexchange | default('ikev1') == 'ikev1' %}
{{ secret_values[connection.xauth_username] }} : XAUTH "{{ secret_values[connection.xauth_password] }}"
{% else %}
{{ secret_values[connection.xauth_username] }} : EAP "{{ secret_values[connection.xauth_password] }}"
{% endif %}
{% endif %}
{% endfor %}

{% if vpn.additional_secrets is defined %}
# Additional secrets
{% for secret in vpn.additional_secrets %}
{{ secret.leftid }} {{ secret.rightid }} : {{ secret.type | upper }} "{{ secret.value }}"
{% endfor %}
{% endif %}
